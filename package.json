{
  "name": "throttled-nodejs",
  "version": "3.2.0",
  "description": "High-performance Node.js rate limiting library with multiple algorithms (Fixed Window, Sliding Window, Token Bucket, Leaky Bucket & GCRA) and storage backends (Redis, In-Memory). Port of throttled-py.",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "scripts": {
    "build": "tsc",
    "test": "jest --config jest.config.js",
    "test:coverage": "jest --config jest.config.js --coverage",
    "test:watch": "jest --config jest.config.js --watch",
    "prepublishOnly": "npm run build"
  },
  "keywords": [
    "rate-limiting",
    "throttle",
    "token-bucket",
    "leaky-bucket",
    "fixed-window",
    "sliding-window",
    "gcra",
    "redis"
  ],
  "license": "MIT",
  "devDependencies": {
    "@types/jest": "^29.5.0",
    "@types/node": "^20.0.0",
    "jest": "^29.7.0",
    "ts-jest": "^29.1.0",
    "typescript": "^5.3.0"
  },
  "optionalDependencies": {
    "ioredis": "^5.4.0",
    "@opentelemetry/api": "^1.9.0"
  }
}
